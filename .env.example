# ── YouTube Data API v3 (업로드 + 통계) ─────────────────────
# 1) Google Cloud Console → 프로젝트 → YouTube Data API v3 활성화
# 2) OAuth 동의 화면 (외부) — 스코프 두 개 필수:
#    - https://www.googleapis.com/auth/youtube.upload
#    - https://www.googleapis.com/auth/youtube.readonly      (통계 조회용)
# 3) 사용자 인증 정보 → OAuth 클라이언트 ID (데스크톱 앱) → JSON 다운로드
#    → tools/client_secret.json 으로 저장
# 4) python tools/youtube_authorize.py 실행 → 출력된 3줄을 여기에 붙여넣기
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Telegram 알림 (선택, 미설정 시 자동 비활성) ─────────────
# 1) BotFather (@BotFather) 에서 /newbot 으로 봇 생성 → 토큰 받기
# 2) 본인 봇과 대화 1회 시작 ("/start" 보내기)
# 3) https://api.telegram.org/bot<TOKEN>/getUpdates 열어서 chat.id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY=1                           # 0/false 로 설정 시 글로벌 OFF
